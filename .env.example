# Flask Security Key
FLASK_SECRET_KEY=replace_this_with_a_secure_random_string

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password

# CLOUD DEPLOYMENT VARIABLES (For Render.com / Production)
# Get from Neon.tech (Starts with postgres:// or postgresql://)
DATABASE_URL=

# Get from Cloudinary.com Dashboard (Starts with cloudinary://)
CLOUDINARY_URL=
